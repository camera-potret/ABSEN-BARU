{
  "buildCommand": "pip install -r requirements.txt",
  "runtime": "python3.9",
  "functions": {
    "wsgi.py": {
      "runtime": "python3.9"
    }
  },
  "routes": [
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "SQLALCHEMY_DATABASE_URI": {
      "description": "Database connection string",
      "value": "sqlite:///absensi.db"
    }
  }
}
